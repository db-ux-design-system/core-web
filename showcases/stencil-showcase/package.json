{
  "name": "stencil-showcase",
  "version": "0.0.0",
  "type": "module",
  "description": "Stencil showcase",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/db-ux-design-system/core-web.git"
  },
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @db-ux/wc-core-components run dev-build && vite build",
    "dev": "pnpm --filter @db-ux/wc-core-components run dev-build && vite --open",
    "preview": "npx http-server ../../build-showcases",
    "start": "vite",
    "test:a11y-checker": "cross-env showcase=stencil-showcase npx playwright test --config=../playwright.a11y-checker.ts",
    "test:aria-snapshots": "cross-env showcase=stencil-showcase npx playwright test --config=../playwright.aria-snapshots.ts",
    "test:axe-core": "cross-env showcase=stencil-showcase npx playwright test --config=../playwright.axe-core.ts",
    "test:e2e": "cross-env showcase=stencil-showcase npx playwright test --config=../playwright.config.ts",
    "test:ui": "cross-env showcase=stencil-showcase npx playwright test --config=../playwright.config.ts --ui",
    "test:visual-snapshots": "cross-env showcase=stencil-showcase npx playwright test --config=../playwright.visual-snapshots.ts"
  },
  "dependencies": {
    "@db-ux/core-components": "workspace:*",
    "@db-ux/core-foundations": "workspace:*",
    "@db-ux/db-theme": "5.7.0",
    "@db-ux/db-theme-fonts": "2.0.5",
    "@db-ux/db-theme-icons": "3.9.0",
    "@db-ux/wc-core-components": "workspace:*"
  },
  "devDependencies": {
    "cross-env": "10.1.0",
    "http-server": "14.1.1",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vite-plugin-static-copy": "4.1.0"
  }
}
