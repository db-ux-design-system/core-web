{
  "name": "angular-ssr-showcase",
  "version": "0.0.0",
  "description": "Angular SSR showcase",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/db-ux-design-system/core-web.git"
  },
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "ng build && cpr ./dist/angular-ssr-showcase/ ../../build-showcases/angular-ssr-showcase/ -d",
    "build:debug": "ng build --optimization=false",
    "dev": "pnpm run start -- --open",
    "ng": "ng",
    "serve:ssr:angular-ssr-showcase": "node dist/angular-ssr-showcase/server/server.mjs",
    "start": "ng serve --serve-path angular-ssr-showcase --port 4401",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/animations": "21.2.10",
    "@angular/common": "21.2.10",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.10",
    "@angular/forms": "21.2.10",
    "@angular/platform-browser": "21.2.10",
    "@angular/platform-browser-dynamic": "21.2.10",
    "@angular/platform-server": "21.2.10",
    "@angular/router": "21.2.10",
    "@angular/ssr": "21.2.9",
    "@db-ux/core-components": "workspace:*",
    "@db-ux/core-foundations": "workspace:*",
    "@db-ux/db-theme": "5.6.2",
    "@db-ux/db-theme-fonts": "2.0.5",
    "@db-ux/db-theme-icons": "3.9.0",
    "express": "5.2.1",
    "rxjs": "7.8.2",
    "tslib": "2.3.0",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.8",
    "@angular/build": "21.2.8",
    "@angular/cli": "21.2.8",
    "@angular/compiler-cli": "21.2.10",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "cpr": "3.0.1",
    "typescript": "5.9.3"
  }
}
