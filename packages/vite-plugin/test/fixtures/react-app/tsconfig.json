{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": true,
		"paths": {
			"@db-ux/react-core-components": ["../../../../../output/react/src"],
			"@db-ux/react-core-components/src/*": [
				"../../../../../output/react/src/*"
			],
			"@db-ux/react-core-components/components/*": [
				"../../../../../output/react/src/components/*"
			]
		}
	},
	"include": ["src"],
	"references": [{ "path": "./tsconfig.node.json" }]
}
