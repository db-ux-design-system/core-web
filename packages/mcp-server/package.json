{
  "name": "@db-ux/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for DB UX Design System – gives LLMs access to UI components and code examples",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/db-ux-design-system/core-web.git"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "db-ux-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "CONTEXT.md",
    "dist"
  ],
  "scripts": {
    "build": "npm run build-manifest && node esbuild.js",
    "build-manifest": "tsx src/build-manifest.ts",
    "dev": "npm run build && node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "esbuild": "0.27.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
