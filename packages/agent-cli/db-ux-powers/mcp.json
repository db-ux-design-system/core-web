{
	"mcpServers": {
		"db-ux": {
			"command": "npx",
			"args": ["--yes", "@db-ux/mcp-server"],
			"tools": [
				"list_components",
				"get_component_props",
				"get_component_details",
				"get_example_code",
				"get_design_tokens",
				"list_design_token_categories",
				"list_icons",
				"docs_search",
				"verify_migrated_code",
				"list_migration_guides",
				"get_migration_guide",
				"scan_v2_migration",
				"list_visuals",
				"get_visual_reference"
			]
		},
		"figma": {
			"command": "npx",
			"args": ["--yes", "@anthropic/mcp-server-figma"],
			"env": {
				"FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}"
			},
			"tools": [
				"figma_get_node",
				"figma_get_file",
				"figma_get_styles",
				"figma_get_variables"
			]
		}
	}
}
