	"_meta": {
		"library": "DB UX DS v3 - Core Components - v4.13.0",
		"libraryKey": "lk-28a3e643a84a4a7eb262f30f43c9e84c74f2e698e3cbaf4a0e91d6f1e00b3d5243c9df8e96e05ff5562fc620238556c89a86ae8bef8c1ce07b7428f9f8b5a960",
		"schema": "Keyed by CANONICAL component (docs/code identity). Figma splits a component into multiple component_sets for performance only; those live under figmaSets with their exact Figma name + key + axes. The agent reasons in canonical name + props; axes resolve to the right figma set key.",
		"resolution": "1) find canonical component by name. 2) match desired props against figmaSets[*].axes. 3) importComponentSetByKeyAsync(key). 4) pick variant child + createInstance(). If no axes match, STOP and report.",
		"naming": "❌ = deprecated, ↳ / 🛟 = helper/subcomponent (only inside parent), (Beta)/(Concept) = maturity.",
		"coreLab": "Concept components in db-lab-component-registry.json (require user confirmation)."
	},

