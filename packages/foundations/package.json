{
  "name": "@db-ux/core-foundations",
  "version": "4.10.1",
  "type": "module",
  "description": "Provides basic tokens and assets based on DB UX Design System (Version 3).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/db-ux-design-system/core-web.git"
  },
  "license": "Apache-2.0",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "module": "./build/index.js",
  "files": [
    "CHANGELOG.md",
    "agent",
    "assets",
    "build"
  ],
  "scripts": {
    "build": "pnpm run build:01_normalize && pnpm run build:02_copy && pnpm run build:03_css && pnpm run build:04_tailwind && pnpm run build:05_postcss && pnpm run build:05_tailwind_scss && pnpm run build:06_ide && pnpm run build:06_ts",
    "build:01_normalize": "pnpm run copy-prepare:icon-overview && pnpm run copy-prepare:normalize",
    "build:02_copy": "pnpm run copy:scss",
    "build:03_css": "sass --no-source-map --load-path=node_modules/ --load-path=../../node_modules/ build/styles",
    "build:04_tailwind": "cpr tailwind build/tailwind --overwrite",
    "build:05_postcss": "postcss build/styles/**/*.css --replace",
    "build:05_tailwind_scss": "sass --no-source-map build/tailwind/theme",
    "build:06_ide": "cpr ide build/ide --overwrite",
    "build:06_ts": "tsc",
    "clean": "rm --recursive --force build",
    "copy-output": "pnpm run copy-output:agent && pnpm run copy-output:assets && pnpm run copy-output:changelog && pnpm run copy-output:package.json && pnpm run copy-output:readme && pnpm run copy-output:web",
    "copy-output:agent": "cpr agent ../../build-outputs/foundations/agent --overwrite",
    "copy-output:assets": "cpr assets ../../build-outputs/foundations/assets --overwrite",
    "copy-output:changelog": "cpr CHANGELOG.md ../../build-outputs/foundations/CHANGELOG.md --overwrite",
    "copy-output:package.json": "cpr package.json ../../build-outputs/foundations/package.json --overwrite",
    "copy-output:readme": "cpr README.md ../../build-outputs/foundations/README.md --overwrite",
    "copy-output:web": "cpr build ../../build-outputs/foundations/build --overwrite",
    "copy-prepare:icon-overview": "tsx scripts/local/generate-icon-overview.ts && prettier dev/icons.html --write",
    "copy-prepare:normalize": "cpr node_modules/@csstools/normalize.css/normalize.css scss/_normalize.scss --overwrite",
    "copy:scss": "cpr scss build/styles --overwrite",
    "dev": "pnpm run copy-prepare:icon-overview && pnpm run copy-prepare:normalize && pnpm run dev:vite",
    "dev:vite": "vite --open",
    "generate:fallback-icon-font": "tsx scripts/local/generate-fallback-icon-font.ts",
    "generate:fonts": "tsx assets/fonts/generate-eu-fonts.ts",
    "generate:icons": "tsx scripts/local/generate-icon-font.ts",
    "regenerate:screenshots": "pnpm exec playwright test --config ./test/playwright.config.js --update-snapshots",
    "start": "pnpm run copy-prepare:icon-overview && pnpm run copy-prepare:normalize && pnpm run start:nodemon",
    "start:nodemon": "nodemon --config nodemon.json",
    "test:e2e": "pnpm exec playwright test --config=./test/playwright.config.js"
  },
  "devDependencies": {
    "@csstools/normalize.css": "12.1.1",
    "@db-ux/icon-font-tools": "0.3.6",
    "@playwright/test": "1.60.0",
    "cpr": "3.0.1",
    "cssnano": "8.0.1",
    "nodemon": "3.1.14",
    "postcss": "8.5.15",
    "postcss-cli": "11.0.1",
    "prettier": "3.8.3",
    "sass": "1.100.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vite": "8.0.16"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
