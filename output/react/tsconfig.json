{
	"compilerOptions": {
		"strict": false,
		"allowUnreachableCode": false,
		"allowSyntheticDefaultImports": true,
		"declaration": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"esModuleInterop": true,
		"lib": ["dom", "es2022"],
		"module": "node16",
		"moduleResolution": "node16",
		"noImplicitAny": false,
		"noImplicitReturns": false,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"outDir": "dist",
		"removeComments": false,
		"rootDir": "./src",
		"sourceMap": true,
		"jsx": "react-jsx",
		"target": "es2022",
		"types": [],
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"node_modules",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"src/**/*.example.tsx",
		"src/**/*.showcase.tsx",
		"src/**/*.showcase-only.tsx",
		"src/**/*.arg.types.ts"
	],
	"compileOnSave": false,
	"buildOnSave": false
}
