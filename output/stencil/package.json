{
  "name": "@db-ux/wc-core-components",
  "version": "4.9.0",
  "type": "module",
  "description": "Stencil components for @db-ux/core-components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/db-ux-design-system/core-web.git"
  },
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/loader/index.d.ts",
      "import": "./dist/loader/index.js"
    },
    "./bundle": {
      "types": "./bundle/index.d.ts",
      "import": "./bundle/index.js"
    }
  },
  "files": [
    "CHANGELOG.md",
    "agent",
    "bundle/",
    "dist/"
  ],
  "scripts": {
    "build": "npm-run-all build:* --parallel mv:*",
    "build:_stencil": "stencil build",
    "build:cem": "cem analyze",
    "dev-build": "stencil build --config stencil.config.dev.ts",
    "mv:agent": "cpr agent ../../build-outputs/wc-core-components/agent --overwrite",
    "mv:bundle": "cpr bundle ../../build-outputs/wc-core-components/bundle --overwrite",
    "mv:changelog": "cpr CHANGELOG.md ../../build-outputs/wc-core-components/CHANGELOG.md --overwrite",
    "mv:dist": "cpr dist ../../build-outputs/wc-core-components/dist --overwrite",
    "mv:package.json": "cpr package.json ../../build-outputs/wc-core-components/package.json --overwrite",
    "mv:readme": "cpr README.md ../../build-outputs/wc-core-components/README.md --overwrite",
    "start": "stencil build --watch --config stencil.config.dev.ts"
  },
  "dependencies": {
    "@db-ux/core-components": "workspace:*",
    "@db-ux/core-foundations": "workspace:*"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@stencil/core": "4.43.4",
    "@types/node": "25.9.0",
    "cem-plugin-expanded-types": "1.4.0",
    "cpr": "3.0.1",
    "custom-element-jet-brains-integration": "1.7.0",
    "custom-element-vs-code-integration": "1.5.0",
    "npm-run-all2": "8.0.4",
    "storybook": "10.4.0",
    "workbox-build": "7.4.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "customElements": "dist/custom-elements.json",
  "web-types": "./dist/web-types.json"
}
