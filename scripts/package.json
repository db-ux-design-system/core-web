{
  "name": "scripts",
  "version": "0.0.0",
  "type": "module",
  "description": "contains scripts for monorepo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/db-ux-design-system/core-web.git"
  },
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "agent": "run-p agent:00_* && pnpm run agent:01_merge_docs",
    "agent:00_extract-css": "tsx documentation/extract-css-vars.ts",
    "agent:00_mitosis-agent": "pnpm --filter @db-ux/core-components run generate:agent",
    "agent:01_merge_docs": "tsx documentation/merge-component-docs.ts",
    "agent:x00_typedoc": "typedoc --options typedoc.json --tsconfig tsconfig.typedoc.json",
    "build": "pnpm run build:foundations && pnpm run build:components && run-p build:migration build:stylelint build:eslint-plugin build:postcss-plugin build:vite-plugin build:agent-cli build:mcp-server",
    "build-outputs": "run-p build-outputs:*",
    "build-outputs:agent-cli": "pnpm --filter @db-ux/agent-cli run copy-output",
    "build-outputs:components": "pnpm --filter @db-ux/core-components run copy-output",
    "build-outputs:eslint-plugin": "pnpm --filter @db-ux/core-eslint-plugin run copy-output",
    "build-outputs:foundations": "pnpm --filter @db-ux/core-foundations run copy-output",
    "build-outputs:mcp-server": "pnpm --filter @db-ux/mcp-server run copy-output",
    "build-outputs:migration": "pnpm --filter @db-ux/core-migration run copy-output",
    "build-outputs:ngx-core-components": "pnpm --filter @db-ux/ngx-core-components run build",
    "build-outputs:postcss-plugin": "pnpm --filter @db-ux/core-postcss-plugin run copy-output",
    "build-outputs:react-core-components": "pnpm --filter @db-ux/react-core-components run build",
    "build-outputs:stylelint": "pnpm --filter @db-ux/core-stylelint run copy-output",
    "build-outputs:v-core-components": "pnpm --filter @db-ux/v-core-components run build",
    "build-outputs:vite-plugin": "pnpm --filter @db-ux/core-vite-plugin run copy-output",
    "build-outputs:wc-core-components": "pnpm --filter @db-ux/wc-core-components run build",
    "build-showcases": "run-p build-showcases:*",
    "build-showcases:angular": "pnpm --filter angular-showcase run build",
    "build-showcases:angular-ssr": "pnpm --filter angular-ssr-showcase run build",
    "build-showcases:next": "pnpm --filter next-showcase run build",
    "build-showcases:nuxt": "pnpm --filter nuxt-showcase run generate",
    "build-showcases:patternhub": "pnpm --filter patternhub run build",
    "build-showcases:react": "pnpm --filter react-showcase run build",
    "build-showcases:stencil": "pnpm --filter stencil-showcase run build",
    "build-showcases:vue": "pnpm --filter vue-showcase run build",
    "build-storybooks": "run-p build-storybooks:*",
    "build-storybooks:angular": "pnpm --filter angular-storybook run build",
    "build-storybooks:composition": "pnpm --filter composition-storybook run build",
    "build-storybooks:react": "pnpm --filter react-storybook run build",
    "build-storybooks:vue": "pnpm --filter vue-storybook run build",
    "build:agent-cli": "pnpm --filter @db-ux/agent-cli run build",
    "build:components": "pnpm --filter @db-ux/core-components run build",
    "build:eslint-plugin": "pnpm --filter @db-ux/core-eslint-plugin run build",
    "build:foundations": "pnpm --filter @db-ux/core-foundations run build",
    "build:mcp-server": "pnpm --filter @db-ux/mcp-server run build",
    "build:migration": "pnpm --filter @db-ux/core-migration run build",
    "build:postcss-plugin": "pnpm --filter @db-ux/core-postcss-plugin run build",
    "build:stylelint": "pnpm --filter @db-ux/core-stylelint run build",
    "build:vite-plugin": "pnpm --filter @db-ux/core-vite-plugin run build",
    "dev": "tsx dev.js",
    "dev:angular-components": "pnpm --filter @db-ux/core-components run dev:angular",
    "dev:plain-html-components": "pnpm --filter @db-ux/core-components run dev:html",
    "dev:react-components": "pnpm --filter @db-ux/core-components run dev:react",
    "dev:sass": "pnpm --filter @db-ux/core-components run dev:scss",
    "dev:stencil-components": "pnpm --filter @db-ux/core-components run dev:stencil",
    "dev:vue-components": "pnpm --filter @db-ux/core-components run dev:vue",
    "docs-file-references": "node check-docs.js",
    "rm:builds": "tsx rm-builds.ts",
    "start-showcase:angular": "pnpm --filter angular-showcase run dev",
    "start-showcase:angular-ssr": "pnpm --filter angular-ssr-showcase run dev",
    "start-showcase:next": "pnpm --filter next-showcase run dev",
    "start-showcase:nuxt": "pnpm --filter nuxt-showcase run dev",
    "start-showcase:patternhub": "pnpm --filter patternhub run dev",
    "start-showcase:react": "pnpm --filter react-showcase run dev",
    "start-showcase:stencil": "pnpm --filter stencil-showcase run dev",
    "start-showcase:vue": "pnpm --filter vue-showcase run dev",
    "start:foundations": "pnpm --filter @db-ux/core-foundations run start",
    "test": "run-p test:*",
    "test:agent-cli": "pnpm --filter @db-ux/agent-cli run test",
    "test:components": "pnpm --filter @db-ux/core-components run test",
    "test:eslint-plugin": "pnpm --filter @db-ux/core-eslint-plugin run test",
    "test:mcp-server": "pnpm --filter @db-ux/mcp-server run test",
    "test:migration": "pnpm --filter @db-ux/core-migration run test",
    "test:postcss-plugin": "pnpm --filter @db-ux/core-postcss-plugin run test",
    "test:scripts": "vitest run --config vitest.config.ts",
    "update:icon-fonts": "pnpm run generate:icon-fonts && pnpm run generate:icon-types"
  },
  "dependencies": {
    "@db-ux/db-theme": "5.6.2",
    "@db-ux/db-theme-fonts": "2.0.5",
    "@db-ux/db-theme-icons": "3.9.0",
    "postcss-scss": "4.0.9"
  },
  "devDependencies": {
    "@inquirer/prompts": "8.4.2",
    "find-versions": "6.0.0",
    "glob": "13.0.6",
    "inquirer": "13.4.2",
    "npm-run-all2": "8.0.4",
    "publint": "0.3.19",
    "replace-in-file": "8.4.0",
    "rimraf": "6.1.3",
    "sassdoc": "2.7.4",
    "tar": "7.5.13",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.11.0",
    "typedoc-plugin-merge-modules": "7.0.0",
    "vitest": "4.1.5"
  }
}
