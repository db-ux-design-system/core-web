erPropValue(prop) {\\n    if (isReactComponentArray(prop)) {\\n        return prop;\\n    }\\n    if (prop === undefined) {\\n        return 'undefined';\\n    }\\n    // Replace any newlines or quotes in the string with escaped versions\\n    if (typeof prop === 'string') {\\n        const str = \`\\"\${prop.replaceAll('\\\\n', '\\\\\\\\n').replaceAll('\\"', '\\\\\\\\\\"')}\\"\`;\\n        if (str === '') {\\n            return 'undefined';\\n        }\\n        else {\\n            return str;\\n        }\\n    }\\n    if (typeof prop === 'boolean' || typeof prop === 'number') {\\n        return prop;\\n    }\\n    if (prop.$type === 'function' ||\\n        prop.$type === 'identifier' ||\\n        prop.$type === 'jsx-element' ||\\n        prop.$type === 'react-component') {\\n        return prop.$value;\\n    }\\n    if (prop.$type === 'array') {\\n        return \`[\${prop.$value.map((el) => _fcc_renderPropValue(el))}]\`;\\n    }\\n    if (prop.$type === 'object') {\\n        return \`{\${Object.keys(prop.$value)\\n            .map((key) => \` \${key}: \${_fcc_renderPropValue(prop.$value[key])} \`)\\n            .join(',')}}\`;\\n    }\\n    if (prop.$type === 'template-string') {\\n        return \`\\\\\`\${prop.$value}\\\\\`\`;\\n    }\\n    return 'undefined';\\n}\\nfunction _fcc_stringifyObject(obj) {\\n    if (Array.isArray(obj)) {\\n        return \`[\${obj.map((element) => \`\${_fcc_stringifyObject(element)}\`).join(',')}]\`;\\n    }\\n    if (typeof obj !== 'object' || obj instanceof Date || obj === null) {\\n        return JSON.stringify(obj);\\n    }\\n    return \`{\${Object.keys(obj)\\n        .map((key) => \` \${key}: \${_fcc_stringifyObject(obj[key])} \`)\\n        .join(',')}}\`;\\n}\\nfunction _fcc_reactComponent($value) {\\n    return {\\n        $value,\\n        $type: 'react-component',\\n    };\\n}\\nfunction _fcc_array($value) {\\n    return {\\n        $value,\\n        $type: 'array',\\n    };\\n}\\nfunction isReactComponentArray(prop) {\\n    return (Array.isArray(prop) &&\\n        prop.every((item) => item.type === 'INSTANCE' ||\\n            item.type === 'SLOT' ||\\n            item.type === 'CODE' ||\\n            item.type === 'ERROR'));\\n}\\n\\nconst figma = require('figma')\\n\\nconst disabled = figma.currentLayer.__properties__.enum('Disabled', {\\n\\"False\\": false,\\n\\"True\\": true})\\nconst noText = figma.currentLayer.__properties__.enum('💻 No Text', {\\n\\"False\\": false,\\n\\"True\\": true})\\nconst size = figma.currentLayer.__properties__.enum('Size', {\\n\\"Small\\": 'small',\\n\\"(Def) Medium\\": 'medium'})\\nconst text = figma.currentLayer.__properties__.string('✏️ Text')\\nconst variant = figma.currentLayer.__properties__.enum('💻 Variant', {\\n\\"Brand\\": 'brand',\\n\\"Ghost\\": 'ghost',\\n\\"Filled\\": 'filled',\\n\\"Outlined\\": 'outlined'})\\nconst width = figma.currentLayer.__properties__.enum('Width', {\\n\\"(Def) Auto\\": 'auto',\\n\\"Full\\": 'full'})\\nconst icon = figma.currentLayer.__properties__.enum('Size', {\\n\\"Small\\": figma.currentLayer.__properties__.instance('🔄 Icon Small'),\\n\\"(Def) Medium\\": figma.currentLayer.__properties__.instance('🔄 Icon Medium')})\\nconst __props = {}\\nif (disabled && disabled.type !== 'ERROR') {\\n  __props[\\"disabled\\"] = disabled\\n}\\nif (noText && noText.type !== 'ERROR') {\\n  __props[\\"noText\\"] = noText\\n}\\nif (size && size.type !== 'ERROR') {\\n  __props[\\"size\\"] = size\\n}\\nif (text && text.type !== 'ERROR') {\\n  __props[\\"text\\"] = text\\n}\\nif (variant && variant.type !== 'ERROR') {\\n  __props[\\"variant\\"] = variant\\n}\\nif (width && width.type !== 'ERROR') {\\n  __props[\\"width\\"] = width\\n}\\nif (icon && icon.type !== 'ERROR') {\\n  __props[\\"icon\\"] = icon\\n}\\n\\nexport default { ...figma.tsx\`<DBButton type=\\"button\\"\${_fcc_renderReactProp('disabled', disabled)}\${_fcc_renderReactProp('noText', noText)}\${_fcc_renderReactProp('icon', icon)}\${_fcc_renderReactProp('width', width)}\${_fcc_renderReactProp('size', size)}\${_fcc_renderReactProp('variant', variant)}>\\n      \${_fcc_renderReactChildren(text)}\\n    </DBButton>\`, metadata: { __props } }\\n",
