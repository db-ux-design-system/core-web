iant.type !== 'ERROR') {\\n  __props[\\"variant\\"] = variant\\n}\\nif (width && width.type !== 'ERROR') {\\n  __props[\\"width\\"] = width\\n}\\nif (showIconLeading && showIconLeading.type !== 'ERROR') {\\n  __props[\\"showIconLeading\\"] = showIconLeading\\n}\\nif (showIconTrailing && showIconTrailing.type !== 'ERROR') {\\n  __props[\\"showIconTrailing\\"] = showIconTrailing\\n}\\nif (iconLeading && iconLeading.type !== 'ERROR') {\\n  __props[\\"iconLeading\\"] = iconLeading\\n}\\nif (iconTrailing && iconTrailing.type !== 'ERROR') {\\n  __props[\\"iconTrailing\\"] = iconTrailing\\n}\\n\\nexport default { ...figma.tsx\`<DBButton type=\\"button\\"\${_fcc_renderReactProp('disabled', disabled)}\${_fcc_renderReactProp('noText', noText)}\${_fcc_renderReactProp('icon', iconLeading)}\${_fcc_renderReactProp('iconTrailing', iconTrailing)}\${_fcc_renderReactProp('showIcon', showIconLeading)}\${_fcc_renderReactProp('showIconTrailing', showIconTrailing)}\${_fcc_renderReactProp('width', width)}\${_fcc_renderReactProp('size', size)}\${_fcc_renderReactProp('variant', variant)}\${_fcc_renderReactProp('showIconLeading', showIconLeading)}>\\n      \${_fcc_renderReactChildren(text)}\\n    </DBButton>\`, metadata: { __props } }\\n",
