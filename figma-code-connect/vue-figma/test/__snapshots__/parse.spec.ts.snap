igma')\\n\\nconst behavior = figma.currentLayer.__properties__.enum('💻 Behavior', {\\n\\"multiple\\": 'multiple',\\n\\"single\\": 'single'})\\nconst variant = figma.currentLayer.__properties__.enum('Variant', {\\n\\"(Def) Divider\\": 'divider',\\n\\"Card\\": 'card'})\\nconst __props = {}\\nif (behavior && behavior.type !== 'ERROR') {\\n  __props[\\"behavior\\"] = behavior\\n}\\nif (variant && variant.type !== 'ERROR') {\\n  __props[\\"variant\\"] = variant\\n}\\n\\nexport default figma.html\`<DBAccordion \${_fcc_renderHtmlAttribute('behavior', behavior)} \${_fcc_renderHtmlAttribute('variant', variant)}\\n    ><DBAccordionItem headlinePlain=\\"Item 1\\">Content 1</DBAccordionItem\\n    ><DBAccordionItem headlinePlain=\\"Item 2\\"\\n      >Content 2</DBAccordionItem\\n    ></DBAccordion\\n  >\`\\n",
