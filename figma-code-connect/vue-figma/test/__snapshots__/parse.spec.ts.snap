igma')\\n\\nconst size = figma.currentLayer.__properties__.enum('Size', {\\n\\"(Def) Small\\": 'small',\\n\\"Medium\\": 'medium'})\\nconst semantic = figma.currentLayer.__properties__.enum('Semantic', {\\n\\"(Def) Adaptive\\": 'adaptive',\\n\\"Critical\\": 'critical',\\n\\"Informational\\": 'informational',\\n\\"Neutral\\": 'neutral',\\n\\"Successful\\": 'successful',\\n\\"Warning\\": 'warning'})\\nconst emphasis = figma.currentLayer.__properties__.enum('Emphasis', {\\n\\"(Def) Weak\\": 'weak',\\n\\"Strong\\": 'strong'})\\nconst placement = figma.currentLayer.__properties__.enum('💻 Placement', {\\n\\"inline\\": 'inline',\\n\\"corner-top-left\\": 'corner-top-left',\\n\\"corner-top-right\\": 'corner-top-right',\\n\\"corner-center-left\\": 'corner-center-left',\\n\\"corner-center-right\\": 'corner-center-right',\\n\\"corner-bottom-left\\": 'corner-bottom-left',\\n\\"corner-bottom-right\\": 'corner-bottom-right'})\\nconst text = figma.currentLayer.__findChildWithCriteria__({ name: '✏️ Text', type: \\"TEXT\\" }).__render__()\\nconst __props = {}\\nif (size && size.type !== 'ERROR') {\\n  __props[\\"size\\"] = size\\n}\\nif (semantic && semantic.type !== 'ERROR') {\\n  __props[\\"semantic\\"] = semantic\\n}\\nif (emphasis && emphasis.type !== 'ERROR') {\\n  __props[\\"emphasis\\"] = emphasis\\n}\\nif (placement && placement.type !== 'ERROR') {\\n  __props[\\"placement\\"] = placement\\n}\\nif (text && text.type !== 'ERROR') {\\n  __props[\\"text\\"] = text\\n}\\n\\nexport default figma.html\`<DBBadge\\n    \${_fcc_renderHtmlAttribute('size', size)}\\n    \${_fcc_renderHtmlAttribute('semantic', semantic)}\\n    \${_fcc_renderHtmlAttribute('emphasis', emphasis)}\\n    \${_fcc_renderHtmlAttribute('placement', placement)}\\n    >\${_fcc_renderHtmlValue(text)}</DBBadge\\n  >\`\\n",
