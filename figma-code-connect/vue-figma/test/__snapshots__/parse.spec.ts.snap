igma')\\n\\nconst headlinePlain = figma.currentLayer.__properties__.string('✏️ Headline')\\nconst disabled = figma.currentLayer.__properties__.enum('Disabled', {\\n\\"False\\": false,\\n\\"True\\": true})\\nconst defaultOpen = figma.currentLayer.__properties__.enum('Open', {\\n\\"False\\": false,\\n\\"True\\": true})\\nconst __props = {}\\nif (headlinePlain && headlinePlain.type !== 'ERROR') {\\n  __props[\\"headlinePlain\\"] = headlinePlain\\n}\\nif (disabled && disabled.type !== 'ERROR') {\\n  __props[\\"disabled\\"] = disabled\\n}\\nif (defaultOpen && defaultOpen.type !== 'ERROR') {\\n  __props[\\"defaultOpen\\"] = defaultOpen\\n}\\n\\nexport default figma.html\`<DBAccordionItem\\n    \${_fcc_renderHtmlAttribute('headlinePlain', headlinePlain)}\\n    \${_fcc_renderHtmlAttribute('disabled', disabled)}\\n    \${_fcc_renderHtmlAttribute('defaultOpen', defaultOpen)}\\n  >\\n    Content\\n  </DBAccordionItem>\`\\n",
